SERVER_PORT=8080

MYSQL_URL=jdbc:mysql://localhost:3306/jarvis?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=change_me

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=3s
REDIS_CONNECT_TIMEOUT=3s

JARVIS_SECURITY_ENABLED=true
JARVIS_JWT_SECRET=change-me-please-change-me-please-change-me
JARVIS_JWT_ISSUER=jarvis-gateway
JARVIS_JWT_EXPIRE_SECONDS=86400

JARVIS_GUARD_ENABLED=true
JARVIS_GUARD_PER_MINUTE_LIMIT=60
JARVIS_GUARD_PER_DAY_QUOTA=2000
JARVIS_GUARD_PER_DAY_PROVIDER_MODEL_QUOTA=500

JARVIS_CONTEXT_CACHE_ENABLED=true
JARVIS_CONTEXT_WINDOW_SIZE=12
JARVIS_CONTEXT_CACHE_TTL_SECONDS=1800

JARVIS_BILLING_ENABLED=true
JARVIS_BILLING_DEFAULT_INPUT_COST_PER1K=0.001
JARVIS_BILLING_DEFAULT_OUTPUT_COST_PER1K=0.002

JARVIS_STREAM_ENABLED=true
JARVIS_STREAM_TTL_SECONDS=86400

JARVIS_CACHE_ENABLED=true
JARVIS_CACHE_CONVERSATION_LIST_TTL_SECONDS=120
JARVIS_CACHE_MESSAGE_LIST_TTL_SECONDS=60
JARVIS_CACHE_HOT_RESPONSE_ENABLED=true
JARVIS_CACHE_HOT_RESPONSE_TTL_SECONDS=45

AI_DEFAULT_PROVIDER=local
AI_FALLBACK_ENABLED=false
AI_FALLBACK_PROVIDER=

# Legacy single-provider config (compatibility)
AI_SERVICE_BASE_URL=http://localhost:8000
AI_SERVICE_CHAT_PATH=/v1/chat
AI_SERVICE_STREAM_PATH=/v1/chat/stream
AI_SERVICE_API_KEY=
AI_SERVICE_MODEL=
AI_SERVICE_CONNECT_TIMEOUT_MS=3000
AI_SERVICE_READ_TIMEOUT_MS=30000
AI_SERVICE_RETRY_ENABLED=false
AI_SERVICE_MAX_RETRIES=0
AI_SERVICE_RETRY_BACKOFF_MS=300

# Local mock/provider
AI_LOCAL_ENABLED=true
AI_LOCAL_BASE_URL=http://localhost:8000
AI_LOCAL_CHAT_PATH=/v1/chat
AI_LOCAL_STREAM_PATH=/v1/chat/stream
AI_LOCAL_MODEL=

# DeepSeek (OpenAI-compatible)
AI_DEEPSEEK_ENABLED=false
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_DEEPSEEK_CHAT_PATH=/v1/chat/completions
AI_DEEPSEEK_STREAM_PATH=/v1/chat/completions
AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_MODEL=deepseek-chat

# Gemini
AI_GEMINI_ENABLED=false
AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
AI_GEMINI_CHAT_PATH=/v1beta/models/{model}:generateContent
AI_GEMINI_STREAM_PATH=/v1beta/models/{model}:streamGenerateContent?alt=sse
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-2.0-flash

# Zhipu GLM (OpenAI-compatible)
AI_GLM_ENABLED=false
AI_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_GLM_CHAT_PATH=/chat/completions
AI_GLM_STREAM_PATH=/chat/completions
AI_GLM_API_KEY=
AI_GLM_MODEL=glm-4-plus

# MiniMax Anthropic-compatible endpoint
AI_MINIMAX_ENABLED=false
AI_MINIMAX_PROTOCOL=ANTHROPIC
AI_MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
AI_MINIMAX_CHAT_PATH=/v1/messages
AI_MINIMAX_STREAM_PATH=/v1/messages
AI_MINIMAX_API_KEY=
AI_MINIMAX_MODEL=MiniMax-M2.5
AI_MINIMAX_API_KEY_HEADER=Authorization
AI_MINIMAX_API_KEY_PREFIX=Bearer
AI_MINIMAX_ANTHROPIC_VERSION=2023-06-01

# Aliyun Qwen via DashScope compatible mode
AI_ALIYUN_ENABLED=false
AI_ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_ALIYUN_CHAT_PATH=/chat/completions
AI_ALIYUN_STREAM_PATH=/chat/completions
AI_ALIYUN_API_KEY=
AI_ALIYUN_MODEL=qwen-plus

# Tencent (configure to your compatible gateway/base URL)
AI_TENCENT_ENABLED=false
AI_TENCENT_BASE_URL=http://localhost:8000
AI_TENCENT_CHAT_PATH=/v1/chat/completions
AI_TENCENT_STREAM_PATH=/v1/chat/completions
AI_TENCENT_API_KEY=
AI_TENCENT_MODEL=hunyuan-standard
