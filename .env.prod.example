# Image tags (M11 release output)
GATEWAY_IMAGE=ghcr.io/your-org/jarvis-gateway-pro:latest
FRONTEND_IMAGE=ghcr.io/your-org/jarvis-gateway-console:latest

# Published ports
FRONTEND_PORT=80
GATEWAY_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379
PROMETHEUS_PORT=19090
ALERTMANAGER_PORT=19093
GRAFANA_PORT=13000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Datastore secrets
MYSQL_ROOT_PASSWORD=change_me
REDIS_PASSWORD=change_me

# Gateway security
JARVIS_JWT_SECRET=change-me-please-change-me-please-change-me

# Agent tool policy center
JARVIS_AGENT_TOOL_POLICY_ENABLED=true
JARVIS_AGENT_TOOL_POLICY_DEFAULT_TIMEOUT_MS=2000
JARVIS_AGENT_TOOL_POLICY_DEFAULT_MAX_RETRIES=0
JARVIS_AGENT_TOOL_POLICY_DEFAULT_IDEMPOTENCY_ENABLED=true
JARVIS_AGENT_TOOL_POLICY_DEFAULT_IDEMPOTENCY_TTL_SECONDS=1800
JARVIS_AGENT_TOOL_POLICY_DEFAULT_TOOL_ENABLED=true

# M17 Knowledge retrieval tuning
JARVIS_KNOWLEDGE_SEARCH_DEFAULT_MODE=hybrid
JARVIS_KNOWLEDGE_SEARCH_MAX_CANDIDATES=200
JARVIS_KNOWLEDGE_SEARCH_DEFAULT_LIMIT=8
JARVIS_KNOWLEDGE_SEARCH_MAX_LIMIT=20
JARVIS_KNOWLEDGE_SEARCH_VECTOR_MIN_SIMILARITY=0.15
JARVIS_KNOWLEDGE_SEARCH_HYBRID_MIN_SCORE=0.10
JARVIS_KNOWLEDGE_SEARCH_HYBRID_KEYWORD_WEIGHT=0.65
JARVIS_KNOWLEDGE_SEARCH_HYBRID_VECTOR_WEIGHT=0.35

# AI route defaults
AI_DEFAULT_PROVIDER=minimax
AI_LOCAL_ENABLED=false
AI_LOCAL_BASE_URL=http://host.docker.internal:8000
AI_LOCAL_CHAT_PATH=/v1/chat
AI_LOCAL_STREAM_PATH=/v1/chat/stream

# Upstream ai-service (A03)
AI_AISERVICE_ENABLED=false
AI_AISERVICE_BASE_URL=http://host.docker.internal:8000
AI_AISERVICE_CHAT_PATH=/api/v1/chat
AI_AISERVICE_STREAM_PATH=/api/v1/chat/stream
AI_AISERVICE_API_KEY=
AI_AISERVICE_API_KEY_HEADER=Authorization
AI_AISERVICE_API_KEY_PREFIX=Bearer
AI_AISERVICE_MODEL=

# A04 optional: run ai-service inside the same compose stack
AI_AISERVICE_COMPOSE_ENABLED=false
AISERVICE_IMAGE=jarvis-ai-service:local
AISERVICE_AUTO_BUILD=true
AISERVICE_BUILD_CONTEXT=../../ai-service
AISERVICE_DOCKERFILE=Dockerfile
AISERVICE_PORT=18000
AIS_AI_DEFAULT_PROVIDER=minimax
AIS_AI_FALLBACK_PROVIDER=mock
AIS_MINIMAX_ENABLED=true
AIS_MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
AIS_MINIMAX_API_KEY=
AIS_MINIMAX_MODEL=MiniMax-M2.5
AIS_MINIMAX_API_KEY_HEADER=Authorization
AIS_MINIMAX_API_KEY_PREFIX=Bearer
AIS_MINIMAX_ANTHROPIC_VERSION=2023-06-01

# GLM
AI_GLM_ENABLED=false
AI_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_GLM_API_KEY=
AI_GLM_MODEL=glm-4-plus

# MiniMax Anthropic-compatible endpoint
AI_MINIMAX_ENABLED=true
AI_MINIMAX_PROTOCOL=ANTHROPIC
AI_MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
AI_MINIMAX_CHAT_PATH=/v1/messages
AI_MINIMAX_STREAM_PATH=/v1/messages
AI_MINIMAX_API_KEY=
AI_MINIMAX_MODEL=MiniMax-M2.5
AI_MINIMAX_API_KEY_HEADER=Authorization
AI_MINIMAX_API_KEY_PREFIX=Bearer
AI_MINIMAX_ANTHROPIC_VERSION=2023-06-01

# DeepSeek
AI_DEEPSEEK_ENABLED=false
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_MODEL=deepseek-chat

# Gemini
AI_GEMINI_ENABLED=false
AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-2.0-flash
